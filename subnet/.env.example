OPENROUTER_API_KEY=your-openrouter-api-key-here
SHIELD_MODEL_PATH=./models/shield_model
SHIELD_MODEL_POLL_INTERVAL_SEC=5

# Network configuration
# Set NEXT_PUBLIC_NETWORK=testnet to run against the Bittensor testnet.
# Leave unset or set to "localnet" for the local Docker chain.
NEXT_PUBLIC_NETWORK=testnet

# Testnet chain endpoint (default when NEXT_PUBLIC_NETWORK=testnet)
CHAIN_ENDPOINT=wss://test.finney.opentensor.ai:443

# Subnet netuid — required for testnet; obtain after running btcli subnet create
NETUID=30
